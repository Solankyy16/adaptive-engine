# MongoDB Atlas connection string
# Get this from: Atlas → Connect → Drivers → Python
MONGODB_URI=mongodb+srv://adaptive_user:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=your_db_name_here

# Groq API Key (FREE) — get from: console.groq.com
GROQ_API_KEY=gsk_your_actual_key_here

# Session config
QUESTIONS_PER_SESSION=10
LEARNING_RATE=0.3
